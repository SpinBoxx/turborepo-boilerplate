// BookingQuote are created when a user requests a quote for a specific room and date range.
// They can then convert the quote into a Booking by completing the payment process.
// This allows us to handle cases where users want to get a price estimate before committing
// to a booking, and also to manage inventory more effectively by reserving rooms for quotes.
model BookingQuote {
  id                             String                 @id @default(cuid())
  user                           User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId                         String?
  hotel                          Hotel                  @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  hotelId                        String
  room                           Room                   @relation(fields: [roomId], references: [id], onDelete: Restrict)
  roomId                         String
  checkInDate                    DateTime
  checkOutDate                   DateTime
  nights                        Int
  quantity                       Int
  guestCount                     Int
  currency                       String                 @default("MGA")
  subtotalAmount                 Int
  discountAmount                 Int                    @default(0)
  taxAmount                      Int                    @default(0)
  platformFeePercentageBasisPoints Int
  platformFeeAmount              Int                    @default(0)
  hotelPayoutAmount              Int
  totalAmount                    Int
  status                         BookingQuoteStatus     @default(ACTIVE)
  expiresAt                      DateTime
  convertedAt                    DateTime?
  cancelledAt                    DateTime?
  specialRequests                String?
  customerFirstName              String
  customerLastName               String
  customerEmail                  String
  customerPhoneNumber            String
  discounts                      BookingQuoteDiscount[]
  paymentAttempts                PaymentAttempt[]
  events                         BookingEvent[]
  booking                        Booking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([hotelId])
  @@index([roomId])
  @@index([status])
  @@index([status, expiresAt])
  @@index([roomId, checkInDate, checkOutDate])
}